{
  "name": "review-rock",
  "version": "0.1.0",
  "description": "Automated PR review using Claude AI via AWS Bedrock with distributed coordination",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "review-rock": "dist/main.js"
  },
  "files": [
    "dist/",
    "review-rock.config.example.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "TROUBLESHOOTING.md"
  ],
  "scripts": {
    "precheck": "./scripts/validate-prerequisites.sh",
    "dev": "tsx src/main.ts",
    "build": "tsc",
    "prepublishOnly": "pnpm run build && pnpm run test:run",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "github",
    "pr",
    "pull-request",
    "review",
    "code-review",
    "claude",
    "ai",
    "bedrock",
    "aws",
    "automation",
    "effect-ts",
    "distributed",
    "coordination"
  ],
  "author": "Ky Davis <ky@validkeys.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kydavis/review-rock.git"
  },
  "homepage": "https://github.com/kydavis/review-rock#readme",
  "bugs": {
    "url": "https://github.com/kydavis/review-rock/issues"
  },
  "dependencies": {
    "@effect/cli": "^0.47.0",
    "@effect/platform": "^0.68.0",
    "@effect/platform-node": "^0.63.0",
    "@effect/schema": "^0.75.0",
    "effect": "^3.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@effect/vitest": "^0.12.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.0.0"
}
