{
  "name": "review-rock",
  "version": "0.1.0",
  "description": "Automated PR review system using Claude via CLI with distributed coordination",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "review-rock": "dist/main.js"
  },
  "scripts": {
    "precheck": "./scripts/validate-prerequisites.sh",
    "dev": "tsx src/main.ts",
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": ["code-review", "claude", "github", "automation", "effect-ts"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@effect/cli": "^0.47.0",
    "@effect/platform": "^0.68.0",
    "@effect/platform-node": "^0.63.0",
    "@effect/schema": "^0.75.0",
    "effect": "^3.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@effect/vitest": "^0.12.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.0.0"
}
